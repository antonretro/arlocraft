{
  "name": "arlocraft",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --base ./",
    "preview": "vite preview",
    "build:web:portable": "vite build --base ./",
    "build:exe": "npm run build:web:portable && npx electron-builder --win portable -c.electronVersion=41.2.0",
    "start:desktop": "node desktop/start-desktop.cjs"
  },
  "build": {
    "appId": "com.arlocraft.game",
    "productName": "ArloCraft",
    "directories": {
      "output": "release_v1_0_0"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "AntonCraft-${version}-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "comlink": "^4.4.2",
    "fastnoise-lite": "^1.1.1",
    "lz-string": "^1.5.0",
    "stats.js": "^0.17.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9"
  }
}
